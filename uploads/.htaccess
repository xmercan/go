# uploads/ klasöründe PHP çalıştırma kesinlikle kapalı
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>

# Sadece izin verilen uzantılara erişim
<FilesMatch "(?i)\.(php|php3|php4|php5|php7|php8|phtml|phar|htaccess|htpasswd)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

Options -Indexes -ExecCGI
