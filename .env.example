# GO.NET.TR — GO! V1
# .env.example — Yapılandırma Şablonu
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# .env dosyası asla versiyon kontrolüne eklenmemeli.

# ─── Uygulama ────────────────────────────────────────────────────────────────
APP_NAME="GO.NET.TR"
APP_URL=https://go.net.tr
APP_KEY=
APP_ENV=production
APP_MODE=production
APP_DEBUG=false
APP_TIMEZONE=Europe/Istanbul
APP_LOCALE=tr

# ─── Veritabanı ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASS=
DB_CHARSET=utf8mb4

# ─── SMTP ────────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME="GO!"

# ─── Storage ─────────────────────────────────────────────────────────────────
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=storage/app

# S3 (V2 — şimdi boş bırakın)
STORAGE_S3_KEY=
STORAGE_S3_SECRET=
STORAGE_S3_REGION=
STORAGE_S3_BUCKET=
STORAGE_S3_URL=

# ─── AI (V1'de kapalı) ───────────────────────────────────────────────────────
AI_ENABLED=false
AI_PROVIDER=
AI_MODEL=
AI_API_KEY=

# ─── Güvenlik ────────────────────────────────────────────────────────────────
SESSION_LIFETIME=120
SESSION_SECURE=true
SESSION_HTTPONLY=true
SESSION_SAMESITE=Lax

# ─── Queue ───────────────────────────────────────────────────────────────────
QUEUE_DRIVER=database
QUEUE_RETRY_AFTER=90

# ─── Cache ───────────────────────────────────────────────────────────────────
CACHE_DRIVER=file
CACHE_TTL_SETTINGS=3600
CACHE_TTL_SECTORS=3600
CACHE_TTL_DASHBOARD=300
